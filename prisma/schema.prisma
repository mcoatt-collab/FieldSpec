generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  email
  google
  github
}

enum TokenType {
  email_verification
  password_reset
}

enum ProjectStatus {
  pending
  processing
  completed
  failed
}

enum JobStatus {
  queued
  processing
  completed
  failed
  cancelled
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String?
  name         String
  companyName  String?
  authProvider AuthProvider @default(email)
  isVerified   Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  authTokens AuthToken[]
  clients    Client[]
  projects   Project[]
}

model AuthToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  type      TokenType
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model Client {
  id          String    @id @default(uuid())
  userId      String
  name        String
  company     String?
  contactInfo String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
}

model Project {
  id         String        @id @default(uuid())
  userId     String
  clientId   String?
  name       String
  status     ProjectStatus @default(pending)
  photoCount Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  images   Image[]
  aiJobs   AIJob[]
  aiOutput AIOutput?
  report   Report?

  @@index([userId])
  @@index([clientId])
}

model Image {
  id           String   @id @default(uuid())
  projectId    String
  url          String
  thumbnailUrl String?
  category     String   @default("general")
  notes        String?
  gpsLat       Float?
  gpsLng       Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AIJob {
  id         String    @id @default(uuid())
  projectId  String
  status     JobStatus @default(queued)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AIOutput {
  id        String   @id @default(uuid())
  projectId String   @unique
  output    Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Report {
  id        String   @id @default(uuid())
  projectId String   @unique
  data      Json?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
